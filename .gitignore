# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Environment variables (never commit secrets) ──────────────────────────────
.env
.env.local
.env*.local

# ── SQLite database files (runtime data, not source) ─────────────────────────
backend/users.db
backend/users.db-shm
backend/users.db-wal

# ── Uploaded images (temporary, auto-deleted by server) ──────────────────────
backend/uploads/

# ── Python virtual environment ────────────────────────────────────────────────
banana-ripeness-ml/venv/
banana-ripeness-ml/__pycache__/
banana-ripeness-ml/**/__pycache__/
*.pyc
*.pyo
*.pyd

# ── Trained ML model files (large binary files) ───────────────────────────────
# Remove these lines if you WANT to commit the model to GitHub
banana-ripeness-ml/model/banana_model.h5
banana-ripeness-ml/model/best_model.h5

# ── Dataset (very large — keep local only) ────────────────────────────────────
Banana Ripeness Classification Dataset/
Banana*/

# ── React build output ────────────────────────────────────────────────────────
frontend/build/
frontend/.env
frontend/.env.local

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
*.tmp
